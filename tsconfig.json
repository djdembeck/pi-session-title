{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@mariozechner/pi-coding-agent": ["./node_modules/@mariozechner/pi-coding-agent"],
      "@oh-my-pi/pi-ai": ["./extensions/types/pi-ai.d.ts"]
    }
  },
  "include": ["./extensions/**/*.ts"],
  "exclude": ["./node_modules", "./dist"]
}
